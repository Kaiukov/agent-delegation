#!/usr/bin/env bash
# Spawn a headless pi worker under a detached tmux session and register it for
# orch-statusline. tmux is session transport only; the worker runtime remains pi.
set -euo pipefail
DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$DIR/.." && pwd)"
RUNNER="$REPO_ROOT/skills/cmux-agent-workflows/scripts/orch-tmux-runner.sh"
BOARD_CONFIG="$REPO_ROOT/bin/board-config"
TMUX_BIN="${TMUX_BIN:-$(command -v tmux || true)}"
DEFAULT_TOOLS="read,bash,edit,write,grep,find,ls"

usage() {
  cat >&2 <<'EOF'
usage: orch-tmux-spawn --issue <id> --worktree <dir> [--task <text>] [--label <text>] [--profile <name> | --model <provider/model>] [--thinking <level>] [--tools <csv>] [--role <name>] [--session <name>]
EOF
}

quote_join() {
  local out="" arg
  for arg in "$@"; do
    if [[ -n "$out" ]]; then out+=" "; fi
    printf -v arg '%q' "$arg"
    out+="$arg"
  done
  printf '%s\n' "$out"
}

ISSUE=""
WORKTREE=""
TASK=""
LABEL=""
PROFILE=""
MODEL=""
THINKING=""
TOOLS=""
ROLE=""
SESSION=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --issue) [[ $# -ge 2 ]] || { usage; exit 2; }; ISSUE="$2"; shift 2 ;;
    --issue=*) ISSUE="${1#--issue=}"; shift ;;
    --worktree) [[ $# -ge 2 ]] || { usage; exit 2; }; WORKTREE="$2"; shift 2 ;;
    --worktree=*) WORKTREE="${1#--worktree=}"; shift ;;
    --task) [[ $# -ge 2 ]] || { usage; exit 2; }; TASK="$2"; shift 2 ;;
    --task=*) TASK="${1#--task=}"; shift ;;
    --label) [[ $# -ge 2 ]] || { usage; exit 2; }; LABEL="$2"; shift 2 ;;
    --label=*) LABEL="${1#--label=}"; shift ;;
    --profile) [[ $# -ge 2 ]] || { usage; exit 2; }; PROFILE="$2"; shift 2 ;;
    --profile=*) PROFILE="${1#--profile=}"; shift ;;
    --model) [[ $# -ge 2 ]] || { usage; exit 2; }; MODEL="$2"; shift 2 ;;
    --model=*) MODEL="${1#--model=}"; shift ;;
    --thinking) [[ $# -ge 2 ]] || { usage; exit 2; }; THINKING="$2"; shift 2 ;;
    --thinking=*) THINKING="${1#--thinking=}"; shift ;;
    --tools) [[ $# -ge 2 ]] || { usage; exit 2; }; TOOLS="$2"; shift 2 ;;
    --tools=*) TOOLS="${1#--tools=}"; shift ;;
    --role) [[ $# -ge 2 ]] || { usage; exit 2; }; ROLE="$2"; shift 2 ;;
    --role=*) ROLE="${1#--role=}"; shift ;;
    --session) [[ $# -ge 2 ]] || { usage; exit 2; }; SESSION="$2"; shift 2 ;;
    --session=*) SESSION="${1#--session=}"; shift ;;
    -h|--help) usage; exit 0 ;;
    *) usage; exit 2 ;;
  esac
done

[[ -n "$ISSUE" && -n "$WORKTREE" ]] || { usage; exit 2; }
[[ -n "$TMUX_BIN" ]] || { echo "ERROR: tmux not found on PATH" >&2; exit 1; }
if [[ -n "$PROFILE" && -n "$MODEL" ]]; then
  echo "ERROR: use either --profile or --model, not both" >&2
  exit 2
fi
if [[ -z "$PROFILE" && -z "$MODEL" ]]; then
  echo "ERROR: missing --profile or --model" >&2
  exit 2
fi

WORKTREE="$(cd "$WORKTREE" && pwd)"
ROLE="${ROLE:-backend}"
TOOLS="${TOOLS:-$DEFAULT_TOOLS}"
PROVIDER=""
MODEL_ID=""

if [[ -n "$PROFILE" ]]; then
  profile_json="$("$BOARD_CONFIG" --get-profile "$PROFILE" --json)"
  PROVIDER="$(jq -r '.provider' <<<"$profile_json")"
  MODEL_ID="$(jq -r '.model' <<<"$profile_json")"
  THINKING="${THINKING:-$(jq -r '.thinking' <<<"$profile_json")}"
  TOOLS="${TOOLS:-$(jq -r '.tools' <<<"$profile_json")}"
  ROLE="${ROLE:-$(jq -r '.role // "backend"' <<<"$profile_json")}"
else
  [[ "$MODEL" == */* ]] || { echo "ERROR: --model must be provider/model" >&2; exit 2; }
  PROVIDER="${MODEL%%/*}"
  MODEL_ID="${MODEL#*/}"
  THINKING="${THINKING:-medium}"
fi

MODEL_FULL="$PROVIDER/$MODEL_ID"
SESSION="${SESSION:-orch-${ISSUE}-${ROLE}}"
RUNS_DIR="$REPO_ROOT/.tasks/orchestrator/runs"
LOGS_DIR="$REPO_ROOT/.tasks/orchestrator/logs"
mkdir -p "$RUNS_DIR" "$LOGS_DIR"
ts="$(date -u +%Y%m%dT%H%M%SZ)"
RUN_ID="${ISSUE}-${ROLE}-${ts}"
RUN_FILE="$RUNS_DIR/${RUN_ID}.json"
LOG_FILE="$LOGS_DIR/${RUN_ID}.log"
branch="$(git -C "$WORKTREE" rev-parse --abbrev-ref HEAD 2>/dev/null || true)"

jq -n \
  --arg run_id "$RUN_ID" \
  --arg issue "$ISSUE" \
  --arg role "$ROLE" \
  --arg session "$SESSION" \
  --arg worktree "$WORKTREE" \
  --arg task "$TASK" \
  --arg label "$LABEL" \
  --arg status "queued" \
  --arg model "$MODEL_FULL" \
  --arg branch "$branch" \
  --arg provider "$PROVIDER" \
  --arg model_id "$MODEL_ID" \
  --arg thinking "$THINKING" \
  --arg tools "$TOOLS" \
  --arg profile_name "$PROFILE" \
  --arg log_file "$LOG_FILE" \
  --arg created_at "$(date -u +%Y-%m-%dT%H:%M:%SZ)" '
    {
      run_id: $run_id,
      agent: $session,
      issue_number: ($issue | tonumber? // $issue),
      issue: $issue,
      role: $role,
      session: $session,
      tmux_session: $session,
      worktree: $worktree,
      worktree_path: $worktree,
      task: $task,
      label: $label,
      status: $status,
      model: $model,
      branch: $branch,
      branch_name: $branch,
      log_file: $log_file,
      created_at: $created_at,
      last_seen_head: null,
      last_seen_remote_ref: null,
      profile: {
        name: $profile_name,
        provider: $provider,
        model: $model_id,
        thinking: $thinking,
        tools: $tools,
        role: $role
      }
    }
  ' > "$RUN_FILE"

runner_args=(--worktree "$WORKTREE" --run-file "$RUN_FILE" --log-file "$LOG_FILE")
if [[ -n "$PROFILE" ]]; then
  runner_args+=(--profile "$PROFILE")
else
  runner_args+=(--model "$MODEL_FULL")
fi
runner_args+=(--thinking "$THINKING" --tools "$TOOLS" --role "$ROLE")
[[ -n "$LABEL" ]] && runner_args+=(--label "$LABEL")

cmd="$(quote_join "$RUNNER" "${runner_args[@]}")"
"$TMUX_BIN" new-session -d -s "$SESSION" "$cmd"

printf 'session=%s\nrun_id=%s\nrun_file=%s\nlog_file=%s\nmodel=%s\nthinking=%s\n' "$SESSION" "$RUN_ID" "$RUN_FILE" "$LOG_FILE" "$MODEL_FULL" "$THINKING"
