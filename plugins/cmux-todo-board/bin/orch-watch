#!/usr/bin/env bash
# orch-watch — Monitor a headless worker run.
# Watches PID liveness, local HEAD, and remote branch ref.
# Classifies runs as: running, progressed, ready-for-verify, failed, stalled.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

die() { echo "ERROR: $*" >&2; exit 1; }

resolve_target_repo() {
  local candidate="${ORCH_REPO_ROOT:-}"
  if [[ -n "$candidate" ]]; then
    TARGET_REPO="$(git -C "$candidate" rev-parse --show-toplevel 2>/dev/null)" || die "not a git repo: $candidate"
    return
  fi

  candidate="$(git -C "$PWD" rev-parse --show-toplevel 2>/dev/null || true)"
  if [[ -n "$candidate" ]]; then
    TARGET_REPO="$candidate"
    return
  fi

  TARGET_REPO="$PWD"
}

resolve_target_repo
ORCH_DIR="$TARGET_REPO/.tasks/orchestrator"
RUNS_DIR="$ORCH_DIR/runs"

# ─── Defaults ──────────────────────────────────────────────────────────────
POLL_INTERVAL=15
STALE_AFTER=1200   # 20 minutes
HARD_TIMEOUT=3600  # 60 minutes

# ─── Helpers ───────────────────────────────────────────────────────────────
log() { echo "[orch-watch] $*" >&2; }

is_uint() { [[ "${1:-}" =~ ^[0-9]+$ ]]; }

file_read() {
  local f="$1"
  [[ -f "$f" ]] && head -n 1 "$f" || true
}

state_file() { printf '%s/%s.json' "$RUNS_DIR" "$RUN_ID"; }

git_head() {
  local wt="$1"
  git -C "$wt" rev-parse HEAD 2>/dev/null || true
}

remote_ref_exists() {
  local wt="$1" ref="$2"
  git -C "$wt" ls-remote --exit-code origin "${ref#origin/}" >/dev/null 2>&1
}

pid_alive() { kill -0 "$1" 2>/dev/null; }

out_file_indicates_success() {
  local out="$1"
  [[ -f "$out" ]] || return 1
  grep -q 'EXIT=0' "$out" 2>/dev/null && return 0
  grep -q 'CTB-DONE' "$out" 2>/dev/null && return 0
  return 1
}

state_get() {
  local expr="$1"
  jq -r "$expr // empty" "$STATE_FILE" 2>/dev/null || true
}

update_state() {
  local new_state="$1"
  local new_head="$2"
  local new_reason="$3"
  local new_activity="$4"
  local tmp
  tmp="$(mktemp "${STATE_FILE}.XXXXXX")"
  jq -c \
    --arg state "$new_state" \
    --arg head "$new_head" \
    --arg reason "$new_reason" \
    --argjson last_activity "$new_activity" \
    '
      .state = $state
      | .last_activity = $last_activity
      | .reason = (if $reason == "" then null else $reason end)
      | if $head == "" then . else .head = $head end
    ' "$STATE_FILE" > "$tmp"
  mv "$tmp" "$STATE_FILE"
}

usage() {
  cat >&2 <<'EOF'
Usage: orch-watch --run-id <ID> [options]

Required:
  --run-id <ID>     Run identifier

Options:
  --pid <PID>       Worker PID to watch (overrides state file)
  --worktree <DIR>  Worktree path (overrides state file)
  --remote-ref <REF> Remote ref to watch (overrides state file)
  --out <FILE>      Worker output file (defaults to <worktree>/out.json)
  --poll <SECS>     Polling interval in seconds (default: 15)
  --stale <SECS>    Stale threshold in seconds (default: 1200 = 20m)
  --timeout <SECS>  Hard timeout in seconds (default: 3600 = 60m)
  --help, -h        Show this help message

State file: .tasks/orchestrator/runs/<run-id>.json
EOF
  exit 0
}

# ─── Arg parse ─────────────────────────────────────────────────────────────
PID=""
RUN_ID=""
WORKTREE=""
REMOTE_REF=""
OUT_FILE=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --pid)        [[ $# -ge 2 ]] || { usage; exit 2; }; PID="$2"; shift 2 ;;
    --pid=*)      PID="${1#--pid=}"; shift ;;
    --run-id)     [[ $# -ge 2 ]] || { usage; exit 2; }; RUN_ID="$2"; shift 2 ;;
    --run-id=*)   RUN_ID="${1#--run-id=}"; shift ;;
    --worktree)   [[ $# -ge 2 ]] || { usage; exit 2; }; WORKTREE="$2"; shift 2 ;;
    --worktree=*) WORKTREE="${1#--worktree=}"; shift ;;
    --remote-ref) [[ $# -ge 2 ]] || { usage; exit 2; }; REMOTE_REF="$2"; shift 2 ;;
    --remote-ref=*) REMOTE_REF="${1#--remote-ref=}"; shift ;;
    --out)        [[ $# -ge 2 ]] || { usage; exit 2; }; OUT_FILE="$2"; shift 2 ;;
    --out=*)      OUT_FILE="${1#--out=}"; shift ;;
    --poll)       [[ $# -ge 2 ]] || { usage; exit 2; }; POLL_INTERVAL="$2"; shift 2 ;;
    --poll=*)     POLL_INTERVAL="${1#--poll=}"; shift ;;
    --stale)      [[ $# -ge 2 ]] || { usage; exit 2; }; STALE_AFTER="$2"; shift 2 ;;
    --stale=*)    STALE_AFTER="${1#--stale=}"; shift ;;
    --timeout)    [[ $# -ge 2 ]] || { usage; exit 2; }; HARD_TIMEOUT="$2"; shift 2 ;;
    --timeout=*)  HARD_TIMEOUT="${1#--timeout=}"; shift ;;
    -h|--help)    usage ;;
    *)            die "unknown flag: $1"; usage ;;
  esac
done

[[ -n "$RUN_ID" ]] || { usage; exit 2; }
is_uint "$POLL_INTERVAL" || die "invalid --poll: $POLL_INTERVAL"
is_uint "$STALE_AFTER" || die "invalid --stale: $STALE_AFTER"
is_uint "$HARD_TIMEOUT" || die "invalid --timeout: $HARD_TIMEOUT"
(( POLL_INTERVAL > 0 && STALE_AFTER > 0 && HARD_TIMEOUT > 0 )) || die "timers must be > 0"

STATE_FILE="$(state_file)"
[[ -f "$STATE_FILE" ]] || die "missing run state: $STATE_FILE"

if [[ -z "$PID" ]]; then
  PID="$(state_get '.pid')"
fi
if [[ -z "$WORKTREE" ]]; then
  WORKTREE="$(state_get '.worktree_path // .worktree')"
fi
if [[ -z "$REMOTE_REF" ]]; then
  REMOTE_REF="$(state_get '.last_seen_remote_ref // .remote_ref // .["remote-ref"]')"
fi
if [[ -z "$OUT_FILE" && -n "$WORKTREE" ]]; then
  OUT_FILE="$WORKTREE/out.json"
fi

[[ -n "$PID" ]] || die "missing worker pid (pass --pid or store pid in $STATE_FILE)"
is_uint "$PID" || die "invalid --pid: $PID"
(( PID > 0 )) || die "invalid --pid: $PID"
is_uint "$POLL_INTERVAL" || die "invalid --poll: $POLL_INTERVAL"
is_uint "$STALE_AFTER" || die "invalid --stale: $STALE_AFTER"
is_uint "$HARD_TIMEOUT" || die "invalid --timeout: $HARD_TIMEOUT"
(( POLL_INTERVAL > 0 && STALE_AFTER > 0 && HARD_TIMEOUT > 0 )) || die "timers must be > 0"

if [[ -n "$WORKTREE" ]]; then
  WORKTREE="$(cd "$WORKTREE" 2>/dev/null && pwd)" || die "worktree not found: $WORKTREE"
fi

# ─── Init state ───────────────────────────────────────────────────────────
mkdir -p "$RUNS_DIR"
NOW="$(date +%s)"
INITIAL_HEAD=""
if [[ -n "$WORKTREE" ]]; then
  INITIAL_HEAD="$(git_head "$WORKTREE")"
fi
update_state "running" "$INITIAL_HEAD" "" "$NOW"

START_TIME="$NOW"
log "watching pid=$PID run=$RUN_ID worktree=${WORKTREE:-none} remote_ref=${REMOTE_REF:-none}"
log "poll=${POLL_INTERVAL}s stale=${STALE_AFTER}s timeout=${HARD_TIMEOUT}s"

# ─── Main loop ─────────────────────────────────────────────────────────────
while true; do
  NOW="$(date +%s)"
  ELAPSED=$(( NOW - START_TIME ))

  if (( ELAPSED >= HARD_TIMEOUT )); then
    log "hard timeout reached (${HARD_TIMEOUT}s), killing pid=$PID"
    kill "$PID" 2>/dev/null || true
    update_state "failed" "" "hard-timeout" "$NOW"
    echo "STATUS=FAILED reason=hard-timeout elapsed=${ELAPSED}s"
    exit 124
  fi

  if pid_alive "$PID"; then
    CURRENT_STATE="$(state_get '.state // "running"')"
    LAST_ACTIVITY="$(state_get '.last_activity')"
    is_uint "$LAST_ACTIVITY" || LAST_ACTIVITY="$START_TIME"

    if [[ -n "$WORKTREE" ]]; then
      CURRENT_HEAD="$(git_head "$WORKTREE")"
      PREV_HEAD="$(state_get '.head')"
      if [[ -n "$CURRENT_HEAD" && "$CURRENT_HEAD" != "$PREV_HEAD" ]]; then
        update_state "progressed" "$CURRENT_HEAD" "" "$NOW"
        log "HEAD advanced: ${PREV_HEAD:0:8}..${CURRENT_HEAD:0:8} → progressed"
      fi
    fi

    CURRENT_STATE="$(state_get '.state // "running"')"
    if [[ "$CURRENT_STATE" == "running" ]]; then
      LAST_ACTIVITY="$(state_get '.last_activity')"
      is_uint "$LAST_ACTIVITY" || LAST_ACTIVITY="$START_TIME"
      IDLE=$(( NOW - LAST_ACTIVITY ))
      if (( IDLE >= STALE_AFTER )); then
        log "stall detected: idle ${IDLE}s >= ${STALE_AFTER}s"
        update_state "stalled" "" "stalled" "$NOW"
      fi
    fi

    sleep "$POLL_INTERVAL"
    continue
  fi

  log "pid=$PID exited"

  SUCCESS=false
  if [[ -n "$OUT_FILE" ]] && out_file_indicates_success "$OUT_FILE"; then
    SUCCESS=true
  fi

  if $SUCCESS; then
    log "process completed successfully"

    if [[ -n "$REMOTE_REF" ]]; then
      if [[ -z "$WORKTREE" ]]; then
        die "remote-ref monitoring requires a worktree"
      fi
      log "waiting for remote ref: $REMOTE_REF"
      REF_WAIT_START="$(date +%s)"
      while true; do
        if remote_ref_exists "$WORKTREE" "$REMOTE_REF"; then
          log "remote ref $REMOTE_REF detected"
          break
        fi
        REF_ELAPSED=$(( $(date +%s) - REF_WAIT_START ))
        if (( REF_ELAPSED >= HARD_TIMEOUT )); then
          log "remote ref $REMOTE_REF never appeared within timeout"
          update_state "failed" "" "remote-ref-timeout" "$(date +%s)"
          echo "STATUS=FAILED reason=remote-ref-timeout"
          exit 124
        fi
        sleep "$POLL_INTERVAL"
      done
    fi

    update_state "ready-for-verify" "" "" "$(date +%s)"
    echo "STATUS=READY_FOR_VERIFY"
    exit 0
  fi

  log "process failed"
  update_state "failed" "" "worker-exit" "$(date +%s)"

  if [[ -f "$OUT_FILE" ]]; then
    echo "STATUS=FAILED (see out file for details)" >&2
    tail -n 8 "$OUT_FILE" >&2 || true
  else
    echo "STATUS=FAILED (no out file provided)" >&2
  fi
  exit 1
done
