#!/usr/bin/env bash
set -euo pipefail

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TARGET_REPO=""
ORCH_TMUX_SPAWN="${ORCH_TMUX_SPAWN:-$DIR/orch-tmux-spawn}"
ROLE_CONFIG="${ROLE_CONFIG:-$DIR/role-config}"

usage() {
  cat >&2 <<'EOF'
usage: orch-spawn --role <role> --task-id <issue> [--repo <path>]
EOF
}

die() {
  echo "ERROR: $*" >&2
  exit 1
}

role=""
task_id_raw=""
repo_arg=""

resolve_target_repo() {
  local candidate="${ORCH_REPO_ROOT:-}"
  if [[ -z "$candidate" && -n "$repo_arg" ]]; then
    candidate="$repo_arg"
  fi
  if [[ -z "$candidate" ]]; then
    candidate="$(git -C "$PWD" rev-parse --show-toplevel 2>/dev/null || true)"
  fi
  [[ -n "$candidate" ]] || die "unable to resolve target repo (set ORCH_REPO_ROOT, pass --repo, or run inside a git repo)"
  TARGET_REPO="$(git -C "$candidate" rev-parse --show-toplevel 2>/dev/null)" || die "not a git repo: $candidate"
}

while (( $# > 0 )); do
  case "$1" in
    --role)
      [[ $# -ge 2 ]] || { usage; exit 2; }
      role="$2"
      shift 2
      ;;
    --role=*)
      role="${1#--role=}"
      shift
      ;;
    --task-id)
      [[ $# -ge 2 ]] || { usage; exit 2; }
      task_id_raw="$2"
      shift 2
      ;;
    --task-id=*)
      task_id_raw="${1#--task-id=}"
      shift
      ;;
    --repo)
      [[ $# -ge 2 ]] || { usage; exit 2; }
      repo_arg="$2"
      shift 2
      ;;
    --repo=*)
      repo_arg="${1#--repo=}"
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      usage
      exit 2
      ;;
  esac
done

[[ -n "$role" && -n "$task_id_raw" ]] || { usage; exit 2; }
[[ -x "$ORCH_TMUX_SPAWN" ]] || die "missing orch-tmux-spawn at $ORCH_TMUX_SPAWN"

issue_digits="$(printf '%s' "$task_id_raw" | grep -oE '[0-9]+' | head -1 || true)"
[[ -n "$issue_digits" ]] || die "task-id must contain an issue number: $task_id_raw"
issue_num="$((10#$issue_digits))"
resolve_target_repo
branch="issue-${issue_num}-${role}"
worktree="$(dirname "$TARGET_REPO")/wt-${branch}"
session="orch-${issue_num}-${role}"

if ! profile_json="$("$ROLE_CONFIG" --get-profile "$role" --json)"; then
  die "role-config failed for role '$role'"
fi
provider="$(jq -r '.provider' <<<"$profile_json")"
model_id="$(jq -r '.model' <<<"$profile_json")"
model="$provider/$model_id"
thinking="$(jq -r '.thinking' <<<"$profile_json")"
tools="$(jq -r '.tools' <<<"$profile_json")"

# --- V1 dispatch is self-contained: the worktree and its task spec must exist
# before orch-tmux-spawn cd's into them. orch-tmux-spawn does NOT create them,
# so do it here (idempotent: never clobber a worktree/spec the orchestrator
# pre-created via the manual wt-new.sh flow).
ensure_worktree() {
  [[ -d "$worktree" ]] && return 0
  local base_ref="${ORCH_BASE_REF:-HEAD}"
  if git -C "$TARGET_REPO" show-ref --verify --quiet "refs/heads/$branch"; then
    git -C "$TARGET_REPO" worktree add "$worktree" "$branch" >&2 \
      || die "git worktree add for existing branch '$branch' failed"
  else
    git -C "$TARGET_REPO" worktree add -b "$branch" "$worktree" "$base_ref" >&2 \
      || die "git worktree add -b '$branch' off '$base_ref' failed"
  fi
}

write_task_spec() {
  local spec="$worktree/.task-spec.md"
  [[ -f "$spec" ]] && return 0
  local body=""
  if body="$( ( cd "$TARGET_REPO" && gh issue view "$issue_num" \
                  --json number,title,body \
                  -q '"# Task: #" + (.number|tostring) + " — " + .title + "\n\n" + .body' \
              ) 2>/dev/null )" && [[ -n "$body" ]]; then
    printf '%s\n' "$body" > "$spec"
  else
    printf '# Task: #%s\n\n(GitHub issue body unavailable — orchestrator must fill in the brief.)\n' \
      "$issue_num" > "$spec"
  fi
}

ensure_worktree
write_task_spec

exec "$ORCH_TMUX_SPAWN" \
  --issue "$issue_num" \
  --worktree "$worktree" \
  --repo-root "$TARGET_REPO" \
  --model "$model" \
  --thinking "$thinking" \
  --tools "$tools" \
  --role "$role" \
  --session "$session"
